# PostgreSQL. Самый быстрый способ без локальной установки — бесплатный Postgres на Neon (neon.tech)
# или Supabase. Скопируй этот файл в .env и подставь строку подключения.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
# DIRECT_URL — прямое подключение для миграций/db push (на Neon: строка БЕЗ -pooler).
# Локально и на не-serverless БД можно указать то же, что DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# Локальный Postgres (если установлен):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tarify?schema=public"

# DaData — адресный слой (ФИАС/ГАР) для автокомплита улиц по всей РФ.
# Необязательно: без ключа автокомплит берёт улицы из локальной базы (seed).
# Бесплатный ключ: https://dadata.ru/api/suggest/address/ (нужен только "API-ключ").
# DADATA_API_KEY="your_dadata_api_key"

# Админка (/admin/*). ОБЯЗАТЕЛЬНО сменить в проде. По умолчанию пароль "admin".
ADMIN_PASSWORD="change-me"
ADMIN_SECRET="change-this-too"

# Базовый URL сайта — для канонических ссылок, sitemap.xml и robots.txt.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Демо-плашка «данные примерные». Выставьте 0, когда зальёте реальное покрытие.
NEXT_PUBLIC_DEMO="1"

# Rate-limit на serverless (несколько инстансов): Upstash Redis (REST).
# Без них лимитер работает in-memory (ок для одного инстанса/локалки).
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="xxxxx"

# Аналитика Plausible (privacy-friendly, без cookie-баннера). Необязательно.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN="ваш-домен.ру"
